# Substitute tag/commit metadata into .git_archival.txt when a
# `git archive` (e.g. a GitHub auto-generated source tarball) is
# produced, so scripts/meson-version.py can recover the version from
# archives that carry neither .git nor a baked _version.txt.
.git_archival.txt export-subst

# Exclude development and CI files from distribution
.gitattributes export-ignore
.gitignore export-ignore
.github export-ignore
.pre-commit-config.yaml export-ignore
.editorconfig export-ignore
.codespell export-ignore
.gitlint export-ignore
.prettierignore export-ignore
.yamllint export-ignore

# Exclude import script and related files
import_files.py export-ignore
import_log.txt export-ignore
IMPORT_SUMMARY.md export-ignore
IMPORTED_FILES.txt export-ignore
CLEANUP_NOTES.txt export-ignore
